# Raaha prototype server — copy to server/.env and fill what you have.
# Any ONE of the LLM keys makes the orchestrator agentic; with none set it
# runs the deterministic fallback engine.

# Option A — Anthropic direct (preferred: native structured outputs)
ANTHROPIC_API_KEY=

# Option B — OpenRouter (used only when ANTHROPIC_API_KEY is empty)
OPENROUTER_API_KEY=
# OpenRouter model slug; openrouter/auto lets their router pick
RAAHA_OPENROUTER_MODEL=openrouter/auto

# ElevenLabs — real multilingual voice for replies (and mic transcription)
ELEVENLABS_API_KEY=
# Optional overrides
RAAHA_EL_VOICE_ID=21m00Tcm4TlvDq8ikWAM
RAAHA_EL_TTS_MODEL=eleven_multilingual_v2

# Misc
RAAHA_SERVER_PORT=8787
RAAHA_K_FLOOR=8
